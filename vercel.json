{
    "version": 2,
    "builds": [
        {
            "src": "next.config.mjs",
            "use": "@vercel/next"
        },
        {
            "src": "server/server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server/server.js"
        }
    ]
}